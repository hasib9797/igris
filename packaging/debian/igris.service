[Unit]
Description=Igris Server Manager
After=network.target

[Service]
Type=simple
WorkingDirectory=/usr/lib/igris
Environment=PYTHONPATH=/usr/lib/igris
ExecStart=/usr/lib/igris/venv/bin/python /usr/lib/igris/cli/igris_cli.py server
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
